  "keyFeatures": [
    "One-click installation of custom apps and site modifications on Samsung TVs",
    "Modular system supporting npm and GitHub-hosted modules",
    "Built-in module manager to add, remove, and configure modules",
    "Auto-launch support for modules and background services",
    "Site modification (mods) to inject JavaScript into TV websites",
    "User-agent customization for compatibility tweaks",
    "Background Node.js service runner for module services",
    "Multi-language UI with 20+ supported languages",
    "TizenBrew Installer desktop app for easy deployment"
  ],
  "publicApiSurface": [
    "package.json#packageType: 'app' | 'mods'",
    "package.json#appName",
    "package.json#appPath",
    "package.json#websiteURL",
    "package.json#main (injection script)",
    "package.json#serviceFile (Node.js service)",
    "package.json#keys (TVInputDevice key list)",
    "package.json#evaluateScriptOnDocumentStart",
    "WebSocket Events: Ready, GetModules, LaunchModule, StartService, GetServiceStatuses, ModuleAction, AppControlData, CanLaunchInDebug, ReLaunchInDebug, GetDebugStatus",
    "ModuleAction actions: add, remove, autolaunch, autolaunchService"
  ]
